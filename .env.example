# ============================================================
# CyTrack — Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.example .env/.env
# 2. Fill in ALL values marked with <REQUIRED>
# 3. NEVER commit the actual .env file to version control
# ============================================================

# ─── Django Core ───────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<REQUIRED — generate a strong random key>

# development | production
DJANGO_ENV=development

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────
DB_NAME=cytrackdb
DB_USER=cytrack
DB_PASSWORD=<REQUIRED>
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Celery broker (usually same as REDIS_URL)
CELERY_BROKER_URL=redis://localhost:6379/0

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins for API access
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Threat Intelligence API Keys ──────────────────────────
# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=<your OTX API key>

# AbuseIPDB — https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=<your AbuseIPDB API key>

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=<your VirusTotal API key>

# ─── AI (Phase 5) ──────────────────────────────────────────
# Google Gemini API key for AI threat summaries
GEMINI_API_KEY=<your Gemini API key>

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Uvicorn (Production) ──────────────────────────────────
PORT=8000
UVICORN_WORKERS=2
