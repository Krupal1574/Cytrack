# ============================================================
# CyTrack .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# --- Django static/media (generated at runtime) ---
staticfiles/
/media/
static/plots/

# --- Environment variables (NEVER commit these) ---
.env/.env
.env.local
.env.production
*.env

# --- Docker ---
.docker/

# --- Testing & Coverage ---
.coverage
htmlcov/
.pytest_cache/
coverage.xml
.tox/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Jupyter ---
*.ipynb_checkpoints

# --- Logs ---
logs/
*.log